pipeline {
agent {
  docker {
    image 'rajugijo/maven-docker-agent:v1'
    args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
  }
}
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed 6002'
        //git branch: 'main', url: 'https://github.com/iam-veeramalla/Jenkins-Zero-To-Hero.git'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
stage('Static Code Analysis') {
  environment {
    SONAR_URL = "http://3.80.167.250:9000"
  }
  steps {
    withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
      sh '''
        apt-get update && apt-get install -y openjdk-17-jdk
        export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
        mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}
      '''
    }
  }
}
stage('Build and Push Docker Image') {
  environment {
    DOCKER_IMAGE = "rajugijo/ultimate-cicd:${BUILD_NUMBER}"
    REGISTRY_CREDENTIALS = credentials('docker-cred')
    DOCKER_API_VERSION = "1.44"
  }
  steps {
    script {
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && docker build -t ${DOCKER_IMAGE} .'
        def dockerImage = docker.image("${DOCKER_IMAGE}")
        docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
            dockerImage.push()
        }
    }
  }
}
stage('Update Deployment File') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'github',
            usernameVariable: 'GIT_USERNAME',
            passwordVariable: 'GIT_PASSWORD'
        )]) {

            sh '''
            set -e

            git config --global --add safe.directory $(pwd)
            git config user.email "gijoraju@gmail.com"
            git config user.name "Gijo Raju"

            DEPLOYMENT_FILE="java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml"

            echo "Updating deployment file..."

            sed -i -E "s|(image: rajugijo/ultimate-cicd:).*|\\1${BUILD_NUMBER}|" "$DEPLOYMENT_FILE"

            echo "Updated file:"
            cat "$DEPLOYMENT_FILE"

            git add "$DEPLOYMENT_FILE"

            if git diff --cached --quiet; then
                echo "No changes detected."
                exit 0
            fi

            git commit -m "Update deployment image to version ${BUILD_NUMBER}"

            # Uncomment after confirming commits work
            # git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/gijoraju/Jenkins-Project.git HEAD:main
            '''
        }
    }
}
  }
}
